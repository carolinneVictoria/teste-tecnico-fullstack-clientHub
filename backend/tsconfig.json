{
    "compilerOptions": {
        "target": "es2020",
        "module": "Node16",
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": ".",
        "outDir": "dist"
    },
    "include": [
        "src/**/*.ts",
        "prisma/**/*.ts",
        "prisma.config.ts"
    ]
}